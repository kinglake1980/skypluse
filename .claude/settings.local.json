{
  "permissions": {
    "allow": [
      "Bash(npm -v)",
      "Bash(npm install *)",
      "Bash(npm --workspace server run build)",
      "Bash(npx tsc *)",
      "Bash(npm --workspace server run dev)",
      "Bash(curl -s http://localhost:8787/api/health)",
      "Bash(git check-ignore *)",
      "Bash(curl -sN --max-time 12 http://localhost:8787/api/stream)",
      "Bash(npm --workspace client run test)",
      "Bash(npm --workspace client run build)",
      "Bash(npm run *)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code}\\\\n\" http://localhost:5173/)",
      "Bash(curl -sN --max-time 12 http://localhost:5173/api/stream)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code}\\\\n\" http://localhost:5174/)",
      "Bash(curl -sN --max-time 12 http://localhost:5174/api/stream)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code}\\\\n\" http://localhost:8787/api/health)",
      "Bash(curl -s -w \"\\\\nHTTP %{http_code}\\\\n\" http://localhost:5174/api/health)",
      "Bash(curl -s --noproxy '*' -o /dev/null -w \"HTTP %{http_code}\\\\n\" http://localhost:5174/)",
      "Bash(curl -s --noproxy '*' -w \"\\\\nHTTP %{http_code}\\\\n\" http://localhost:5174/api/health)",
      "Bash(curl -sN --noproxy '*' --max-time 12 http://localhost:5174/api/stream)",
      "Bash(curl -s --noproxy '*' -w \"\\\\nHTTP %{http_code}\\\\n\" http://127.0.0.1:8787/api/health)",
      "Bash(powershell -NoProfile -Command \"Get-NetTCPConnection -LocalPort 8787 -State Listen -ErrorAction SilentlyContinue | Select-Object -First 3 LocalAddress,LocalPort,OwningProcess | Format-Table -AutoSize | Out-String\")",
      "Bash(curl -s --noproxy '*' -o /dev/null -w \"HTTP %{http_code}\\\\n\" http://127.0.0.1:5173/)",
      "Bash(curl -s --noproxy '*' -w \"\\\\nHTTP %{http_code}\\\\n\" http://127.0.0.1:5173/api/health)",
      "Bash(curl -sN --noproxy '*' --max-time 12 http://127.0.0.1:5173/api/stream)",
      "Bash(npm --workspace server run test)"
    ]
  }
}
