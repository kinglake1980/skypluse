{
  "permissions": {
    "allow": [
      "Bash(npx vite *)",
      "Bash(npx tsx *)",
      "Bash(curl -s --noproxy '*' -w \"  HTTP %{http_code}\\\\n\" http://127.0.0.1:8787/api/health)",
      "Bash(curl -sN --noproxy '*' --max-time 50 http://127.0.0.1:8787/api/stream)",
      "Bash(npx vitest *)",
      "Bash(curl -s --noproxy '*' -o /dev/null -w \"frontend HTTP %{http_code}\\\\n\" http://localhost:5173/)",
      "Bash(curl -s --noproxy '*' -X POST -H \"Content-Type: application/json\" -d '{\"mode\":\"preset\",\"region\":\"bj\"}' http://127.0.0.1:8787/api/region)",
      "Bash(curl -sN --noproxy '*' --max-time 5 http://127.0.0.1:8787/api/stream)",
      "Bash(curl -s --noproxy '*' -X POST -H \"Content-Type: application/json\" -d '{\"mode\":\"preset\",\"region\":\"yrd\"}' http://127.0.0.1:8787/api/region)",
      "Bash(curl -s --noproxy '*' -X POST -H \"Content-Type: application/json\" -d '{\"mode\":\"global\"}' http://127.0.0.1:8787/api/region)",
      "Bash(curl -sN --noproxy '*' --max-time 8 http://127.0.0.1:8787/api/stream)"
    ]
  }
}
