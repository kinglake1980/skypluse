# ── OpenSky(OAuth2 client-credentials,凭证只在后端)──
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# ── DeepSeek / OpenAI 兼容端点(密钥只在后端;baseURL、模型 ID、Key 均可配置)──
DEEPSEEK_API_KEY=
# 兼容任意 OpenAI 协议端点:换厂商只改这三项即可
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
# 深度分析(低频)可选模型,留空则沿用上面的 model
DEEPSEEK_MODEL_PRO=deepseek-v4-pro

# ── 聚焦区域边界框:lamin,lomin,lamax,lomax(默认京津冀)──
REGION_BBOX=38.0,114.0,41.5,119.0

# ── 可选:运行参数(留空则用代码默认值)──
# PORT=8787
# POLL_INTERVAL_MS=10000
# NARRATION_INTERVAL_MS=30000
# REGION_NAME=京津冀
